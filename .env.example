# Lokal utveckling: lämna PROXY_SECRET tom så slipper du header (endast dev).
PORT=3000
PROXY_SECRET=

# RP API base path (default /rp/v6.0). Sätt ny path när BankID publicerar ny breaking URL.
# BANKID_RP_API_PATH=/rp/v6.0

# Prod (samma som Zawajj Firebase secrets)
# BANKID_PFX_PROD: en rad base64 av .pfx — generera med ./scripts/encode-pfx-b64.sh path/to/file.pfx
BANKID_PFX_PROD=
BANKID_PASSPHRASE_PROD=
# Antingen flerraders PEM i BANKID_CA_PROD eller (rekommenderat) en rad base64:
# macOS: base64 -i bankid-root-ca.pem | tr -d '\n'
BANKID_CA_PROD=
BANKID_CA_PROD_B64=

# Test (Zawajj använder BANKID_PFX + BANKID_PASSPHRASE)
BANKID_PFX=
BANKID_PASSPHRASE=
# eller
# BANKID_PFX_TEST=
# BANKID_PASSPHRASE_TEST=

# Supabase (behövs bara för POST /collect när status complete)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
